# ============================================================
# 抖音抓取工具 配置文件 (可选)
# 复制此文件为 .env 并填入你的配置
# ============================================================

# 从浏览器复制的 Cookie (F12 → Application → Cookies → douyin.com)
# 主要需要 ttwid 和 msToken
DOUYIN_COOKIE=ttwid=你的ttwid值; msToken=你的msToken值

# 默认抓取模式: api | browser | playwright
SCRAPE_MODE=api

# 最大抓取页数/滚动次数
MAX_PAGES=10

# 输出目录
OUTPUT_DIR=./output
